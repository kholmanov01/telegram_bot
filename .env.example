# ============================================================
# Enterprise Telegram Task Management Bot — Environment Config
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.
# ============================================================

# --- Telegram ---
BOT_TOKEN=put-your-bot-token-here
# Comma-separated list of Telegram user IDs who are Super Admins on first run.
SUPER_ADMIN_IDS=123456789

# --- PostgreSQL (production — used by docker-compose) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=taskbot
POSTGRES_PASSWORD=taskbot_secret
POSTGRES_DB=taskbot
DATABASE_URL=postgresql+asyncpg://taskbot:taskbot_secret@postgres:5432/taskbot

# For SQLite demo use (no Docker):
# DATABASE_URL=sqlite+aiosqlite:///./taskbot.db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Application ---
APP_ENV=production
APP_TIMEZONE=Asia/Tashkent
LOG_LEVEL=INFO
DEFAULT_LANGUAGE=uz

# Working hours (24h, in APP_TIMEZONE)
WORKING_HOURS_START=09:00
WORKING_HOURS_END=18:00

# Scheduler
SCHEDULER_TIMEZONE=Asia/Tashkent

# --- Webhook mode (set USE_WEBHOOK=true on servers with public HTTPS) ---
# Default = false (long-polling) — works behind NAT, no public URL needed.
USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_PATH=/webhook
HEALTHCHECK_PATH=/health
